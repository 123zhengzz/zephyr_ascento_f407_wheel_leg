/*
 * DJI RoboMaster Development Board Type C, STM32F407IGH6.
 *
 * The board exposes CAN1 on PD0/PD1 and CAN2 on PB5/PB6.
 * This robot uses CAN1 for DM43xx joint motors and CAN2 for DJI M3508 wheels.
 */

/dts-v1/;

#include <st/f4/stm32f407Xg.dtsi>
#include <zephyr/dt-bindings/gpio/gpio.h>
#include <zephyr/dt-bindings/pinctrl/stm32-pinctrl.h>
#include <zephyr/dt-bindings/input/input-event-codes.h>

/ {
	model = "DJI RoboMaster Development Board Type C";
	compatible = "dji,dji-f407igh6-c";

	chosen {
		zephyr,console = &usart1;
		zephyr,shell-uart = &usart1;
		zephyr,sram = &sram0;
		zephyr,flash = &flash0;
		zephyr,canbus = &can1;
	};

	aliases {
		led0 = &red_led;
		led1 = &green_led;
		led2 = &blue_led;
		sw0 = &key0;
		can-joint = &can1;
		can-dm = &can1;
		can-wheel = &can2;
		can-m3508 = &can2;
	};

	leds {
		compatible = "gpio-leds";

		red_led: red_led {
			gpios = <&gpioh 12 GPIO_ACTIVE_HIGH>;
			label = "red";
		};

		green_led: green_led {
			gpios = <&gpioh 11 GPIO_ACTIVE_HIGH>;
			label = "green";
		};

		blue_led: blue_led {
			gpios = <&gpioh 10 GPIO_ACTIVE_HIGH>;
			label = "blue";
		};
	};

	gpio_keys {
		compatible = "gpio-keys";

		key0: key_0 {
			gpios = <&gpioa 0 GPIO_ACTIVE_LOW>;
			label = "KEY";
			zephyr,code = <INPUT_KEY_0>;
		};
	};
};

&clk_hse {
	clock-frequency = <12000000>;
	status = "okay";
};

&pll {
	div-m = <12>;
	mul-n = <336>;
	div-p = <2>;
	div-q = <7>;
	clocks = <&clk_hse>;
	status = "okay";
};

&rcc {
	clocks = <&pll>;
	clock-frequency = <168000000>;
	ahb-prescaler = <1>;
	apb1-prescaler = <4>;
	apb2-prescaler = <2>;
};

&pinctrl {
	usart1_tx_pa9: usart1_tx_pa9 {
		pinmux = <STM32_PINMUX('A', 9, AF7)>;
	};

	usart1_rx_pb7: usart1_rx_pb7 {
		pinmux = <STM32_PINMUX('B', 7, AF7)>;
		bias-pull-up;
	};

	can1_rx_pd0: can1_rx_pd0 {
		pinmux = <STM32_PINMUX('D', 0, AF9)>;
		bias-pull-up;
	};

	can1_tx_pd1: can1_tx_pd1 {
		pinmux = <STM32_PINMUX('D', 1, AF9)>;
	};

	can2_rx_pb5: can2_rx_pb5 {
		pinmux = <STM32_PINMUX('B', 5, AF9)>;
		bias-pull-up;
	};

	can2_tx_pb6: can2_tx_pb6 {
		pinmux = <STM32_PINMUX('B', 6, AF9)>;
	};

	spi1_sck_pb3: spi1_sck_pb3 {
		pinmux = <STM32_PINMUX('B', 3, AF5)>;
	};

	spi1_miso_pb4: spi1_miso_pb4 {
		pinmux = <STM32_PINMUX('B', 4, AF5)>;
	};

	spi1_mosi_pa7: spi1_mosi_pa7 {
		pinmux = <STM32_PINMUX('A', 7, AF5)>;
	};

	adc3_in8_pf10: adc3_in8_pf10 {
		pinmux = <STM32_PINMUX('F', 10, ANALOG)>;
	};
};

&usart1 {
	pinctrl-0 = <&usart1_tx_pa9 &usart1_rx_pb7>;
	pinctrl-names = "default";
	current-speed = <115200>;
	status = "okay";
};

&can1 {
	pinctrl-0 = <&can1_rx_pd0 &can1_tx_pd1>;
	pinctrl-names = "default";
	bitrate = <1000000>;
	status = "okay";
};

&can2 {
	pinctrl-0 = <&can2_rx_pb5 &can2_tx_pb6>;
	pinctrl-names = "default";
	bitrate = <1000000>;
	status = "okay";
};

&spi1 {
	pinctrl-0 = <&spi1_sck_pb3 &spi1_miso_pb4 &spi1_mosi_pa7>;
	pinctrl-names = "default";
	cs-gpios = <&gpioa 4 GPIO_ACTIVE_LOW>, <&gpiob 0 GPIO_ACTIVE_LOW>;
	status = "okay";

	bmi088_accel: bmi088_accel@0 {
		compatible = "bosch,bmi088-accel";
		reg = <0>;
		spi-max-frequency = <8000000>;
	};

	bmi088_gyro: bmi088_gyro@1 {
		compatible = "bosch,bmi088-gyro";
		reg = <1>;
		spi-max-frequency = <8000000>;
	};
};

&adc3 {
	compatible = "st,stm32f4-adc", "st,stm32-adc";
	pinctrl-0 = <&adc3_in8_pf10>;
	pinctrl-names = "default";
	st,adc-prescaler = <2>;
	status = "okay";
};
